# freeside-ruggy environment
#
# Two-environment deploy model (Railway):
#   ENV=staging    → ruggy bot in `project purupuru` Discord guild (test)
#   ENV=production → ruggy bot in `The Honey Jar` guild (live)
#
# Each Railway service has its OWN env block. Iterate freely on
# staging without affecting production. Production may pin to an
# older image while staging continues forward.

# ─── deploy environment marker ─────────────────────────────────────
ENV=staging                              # staging | production

# ─── stub mode (data side; LLM flips on key presence) ──────────────
# When true AND MCP_KEY unset, ruggy uses synthetic ZoneDigest payloads.
# When MCP_KEY is set, real score-mcp is called regardless of STUB_MODE.
STUB_MODE=false

# ─── score-mcp (zerker — production data path, v1.1+) ─────────────
SCORE_API_URL=https://score-api-production.up.railway.app
MCP_KEY=                                 # X-MCP-Key header for /mcp tool calls

# ─── LLM provider routing ──────────────────────────────────────────
# V0.12 default doctrine (operator 2026-05-01): production deploys use
# AWS Bedrock for both digest and chat-mode pipelines. ANTHROPIC_API_KEY
# is the dev/local fallback — when both bedrock env AND ANTHROPIC_API_KEY
# are set, `LLM_PROVIDER=auto` resolves to bedrock (cost-bearing default).
#
# To opt into anthropic-direct in dev, EITHER:
#   - set LLM_PROVIDER=anthropic explicitly, OR
#   - unset AWS_BEARER_TOKEN_BEDROCK + BEDROCK_API_KEY in your shell
LLM_PROVIDER=auto                        # auto | bedrock | anthropic | freeside | stub

# ─── amazon bedrock (production · ES bedrock account) ──────────────
# Required for LLM_PROVIDER=bedrock OR for `auto` to resolve to bedrock.
# Bearer token shape (Loa PR #662) — preferred. AWS_REGION sets the
# control-plane region; BEDROCK_TEXT_REGION is the inference region (the
# Bedrock console pin for the text model — typically us-west-2 for Opus).
AWS_REGION=eu-central-1
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_API_KEY=                         # legacy alias; use AWS_BEARER_TOKEN_BEDROCK
BEDROCK_TEXT_REGION=us-west-2
BEDROCK_TEXT_MODEL_ID=us.anthropic.claude-opus-4-7
# Image surface (satoshi imagegen · separate region)
BEDROCK_STABILITY_MODEL_ID=
BEDROCK_IMAGE_REGION=us-east-1

# ─── anthropic-direct (dev/local fallback · LLM_PROVIDER=anthropic) ─
# When this key is set AND no bedrock env is set, `auto` resolves to
# anthropic. Bedrock wins by preference when both envs are set; leaving
# ANTHROPIC_API_KEY unset in production is defense-in-depth, not the
# primary mechanism.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7          # opus-4-7 | sonnet-4-6 | haiku-4-5-20251001

# ─── freeside agent-gateway (jani — when budget accounting needed) ─
# Used when LLM_PROVIDER=freeside. Anthropic + bedrock paths bypass this.
FREESIDE_BASE_URL=https://api.freeside.0xhoneyjar.xyz
FREESIDE_API_KEY=
FREESIDE_AGENT_MODEL=reasoning           # cheap | fast-code | reviewer | reasoning | architect

# ─── freeside-auth (in-bot wallet → handle resolver, V0.5-C) ──────
# Reads midi_profiles from the migrated Railway Postgres (loa-freeside#153).
# When this is unset the resolve_wallet MCP returns truncated 0x...
# fallback for every wallet (graceful degradation).
RAILWAY_MIBERA_DATABASE_URL=

# ─── Discord delivery — bot client (recommended) or webhook ───────
# Each environment has its OWN bot identity (token) so prod isn't
# accidentally posted-to from staging code. Discord usernames can
# differ (e.g. ruggy#1157 staging, ruggy-prod#XXXX production).
DISCORD_BOT_TOKEN=
DISCORD_WEBHOOK_URL=                     # legacy fallback (single channel)

# ─── Per-zone channel IDs ──────────────────────────────────────────
# STAGING — project purupuru guild (1495534680617910396)
#   stonehenge: 1498822402900230294
#   bear-cave:  1498822450316578907
#   el-dorado:  1498822480587002038
#   owsley-lab: 1498822512442609694
#
# PRODUCTION — The Honey Jar guild (1135545260538339420)
#   stonehenge: 1497618160592097464
#   bear-cave:  1497618042560188517
#   el-dorado:  1497618131269718106  ← discord display: "agora"
#   owsley-lab: 1497617952831176777
#
# Set the appropriate set per Railway service. CODE-side zone IDs
# stay `el-dorado` even when the Discord channel displays "agora"
# — channel IDs are what matter; display names are cosmetic.
DISCORD_CHANNEL_STONEHENGE=
DISCORD_CHANNEL_BEAR_CAVE=
DISCORD_CHANNEL_EL_DORADO=
DISCORD_CHANNEL_OWSLEY_LAB=

# ─── future zones (operator pick: prep for 5 dim zones + hub = 6) ─
# Add when score-mibera adds tl/irl scoring + Eileen names channels:
# DISCORD_CHANNEL_TL=                    # Timeline / HÖR (NOT LIVE)
# DISCORD_CHANNEL_IRL=                   # Poppy Field (NOT LIVE)

# ─── V0.7-A.0 — Discord Interactions endpoint (slash commands) ────
# When DISCORD_PUBLIC_KEY is set, the bot starts an HTTP server that
# receives signed slash-command POSTs from Discord and replies via the
# chat-mode pipeline (composeReply). When unset, slash commands are
# disabled but the digest cron path is unaffected.
#
# Setup walkthrough: docs/DISCORD-INTERACTIONS-SETUP.md
# 1. Discord developer portal → Application → General Information
# 2. Set "Interactions Endpoint URL" to https://<host>/webhooks/discord
# 3. Copy the "Public Key" field into DISCORD_PUBLIC_KEY below
# 4. Run: bun run apps/bot/scripts/publish-commands.ts
DISCORD_PUBLIC_KEY=
INTERACTIONS_PORT=3001

# ─── target / cadence ──────────────────────────────────────────────
ZONES=                                   # csv subset; empty = all configured zones
DIGEST_CADENCE=weekly                    # weekly | daily | manual
DIGEST_DAY=sunday
DIGEST_HOUR_UTC=0

# ─── pop-in random cadence ─────────────────────────────────────────
POP_IN_ENABLED=true
POP_IN_INTERVAL_HOURS=6
POP_IN_PROBABILITY=0.1                   # per-zone per-tick (~1-2/day default)

# ─── weaver weekly mid-week (cross-zone) ───────────────────────────
WEAVER_ENABLED=true
WEAVER_DAY=wednesday
WEAVER_HOUR_UTC=12
WEAVER_PRIMARY_ZONE=stonehenge

# ─── cycle-003 · ambient events as rave (V0.7-A.5) ─────────────────
# 4-axis kansei stir (press · strangers · gravity · drift) layered onto
# rosenzu state as a SIBLING channel. Stir-tier polls score-mibera bronze
# every hour; events bend the existing KansaiVector via furnish_kansei
# extension; pop-in cadence becomes reactive to stir drift instead of
# pure die-roll. Source of truth: grimoires/loa/context/ambient-events-as-rave.md
EVENT_HEARTBEAT_ENABLED=true             # default true; set false to disable stir tier without affecting digest cron (D19 invariant)
EVENT_HEARTBEAT_EXPR="0 * * * *"         # cron expr; default hourly
EVENT_CLASSES_ENABLED=awakening,cross_wallets,return_to_source,reveal,backing,committed,fracture  # canon class names (D7)
EVENT_RAVE_HALF_LIFE_HOURS=6             # stir decay half-life (D18 floor 0.05 preserved)
EVENT_GRAVITY_WINDOW_MINUTES=60          # gravity transient flag window (D21 ALEXANDER · IMP-002)
EVENT_LATE_ARRIVAL_HOURS=6               # late-arrival reject horizon (IMP-013 split from half-life)
EVENT_POP_IN_REFRACTORY_HOURS=4          # per-zone refractory (D15 OSTROM)
EVENT_POP_IN_DAILY_CAP=3                 # per-zone pop-ins per UTC day (D15 OSTROM)
EVENT_POP_IN_THRESHOLD_PRESS=0.55        # per-axis OR-gate threshold (D14)
EVENT_POP_IN_THRESHOLD_STRANGERS=0.45
EVENT_POP_IN_THRESHOLD_GRAVITY=0.7       # also stochastic class-A bypass probability (D16)
EVENT_POP_IN_THRESHOLD_DRIFT=0.5
EVENT_CURSOR_FILE=.run/event-cursor.jsonl  # cursor checkpoint (NFR-22 flock under singleton invariant NFR-21)
# BB F10 closure — per-MCP endpoint URLs (lookup_mibera lives on codex-mcp,
# resolve_wallet lives on freeside-auth-mcp, NOT on score-mcp). Set these
# before enabling the wallet/mibera resolvers in production.
CODEX_MCP_URL=
CODEX_MCP_KEY=
FREESIDE_AUTH_MCP_URL=
FREESIDE_AUTH_MCP_KEY=
# BB F3 closure (NFR-30) — comma-separated allowlist of permitted MCP hostnames.
# Empty = allowlist disabled (allows any https hostname). https:// always
# required in production (NODE_ENV=production).
MCP_ENDPOINT_ALLOWLIST=

# ─── meta ──────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
