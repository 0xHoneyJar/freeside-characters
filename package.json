{
  "name": "freeside-ruggy",
  "version": "0.1.0",
  "private": true,
  "description": "Persona-layer Discord bot for the HoneyJar ecosystem. Activity reporter for mibera-dimensions.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/bot dev",
    "start": "bun run --cwd apps/bot start",
    "build": "bun run --cwd apps/bot build",
    "test": "bun run --cwd apps/bot test",
    "typecheck": "bun run --cwd apps/bot typecheck",
    "digest:once": "bun run --cwd apps/bot digest:once"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/bun": "latest"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
