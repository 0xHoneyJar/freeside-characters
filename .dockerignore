# Source-controlled but not needed in image
.git
.github
.claude
.vscode
.idea
docs
README.md
*.md

# Local dev artifacts — depth-aware patterns since Dockerfile uses
# wholesale `COPY apps` / `COPY packages` (.dockerignore is the security
# boundary for accidental secret/cruft inclusion in the image).
**/.env
**/.env.*
!**/.env.example
**/*.log
**/.DS_Store

# Deps + build outputs (rebuilt in image)
**/node_modules
**/dist
**/.bun
**/.turbo
**/coverage

# Bot runtime state — written at runtime, ephemeral per instance
apps/bot/.run

# Workspaces we don't deploy
construct-creator
docs
grimoires
